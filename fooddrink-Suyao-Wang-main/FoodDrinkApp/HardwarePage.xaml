<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="18">
            <Border StrokeThickness="0" Padding="20" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,4" Radius="12" Opacity="0.25" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mobile hardware"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Food photo" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}" />
                            <Label Text="Capture the colour and condition of the meal." FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Padding="16,12"
                                CornerRadius="10"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Meal location" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TertiaryAccent}, Dark={StaticResource TertiaryLight}}" />
                            <Label Text="Show country, city, region, and coordinates." FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="{AppThemeBinding Light={StaticResource TertiaryAccent}, Dark={StaticResource TertiaryLight}}"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Padding="16,12"
                                CornerRadius="10"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Button Text="Read help"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryAccent}, Dark={StaticResource SecondaryLight}}"
                        TextColor="#FFFFFF"
                        FontAttributes="Bold"
                        Padding="16,14"
                        CornerRadius="12"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />
                <Button Grid.Column="1"
                        Text="Stop speech"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                        BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}"
                        FontAttributes="Bold"
                        Padding="16,14"
                        CornerRadius="12"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />
            </Grid>

            <Button Text="Haptic feedback"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}"
                    FontAttributes="Bold"
                    Padding="16,14"
                    CornerRadius="12"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryLight}, Dark={StaticResource SecondaryDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryAccent}, Dark={StaticResource SecondaryLight}}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
