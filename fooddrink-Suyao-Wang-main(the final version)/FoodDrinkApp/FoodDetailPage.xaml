<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="18">
            <Border StrokeThickness="0" Padding="22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDark}}" Offset="0.6" />
                        <GradientStop Color="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TertiaryDark}}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,6" Radius="16" Opacity="0.35" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label x:Name="NameLabel"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="16"
                           TextColor="#FFFFFF" />
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nutrition overview" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}" />
                    <Label x:Name="MacroLabel" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource TertiaryAccent}, Dark={StaticResource TertiaryLight}}" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                    <Label x:Name="DescriptionLabel" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    <Label x:Name="AllergyLabel" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource SecondaryAccent}, Dark={StaticResource SecondaryLight}}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Button Text="Read summary"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}"
                        TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                        BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

            <Button Text="Vibration reminder"
                    BackgroundColor="{AppThemeBinding Light={StaticResource TertiaryAccent}, Dark={StaticResource TertiaryLight}}"
                    TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
