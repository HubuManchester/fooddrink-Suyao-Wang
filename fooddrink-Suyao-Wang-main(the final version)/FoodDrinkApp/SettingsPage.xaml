<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="18">
            <Border StrokeThickness="0" Padding="20" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,4" Radius="12" Opacity="0.25" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Accessibility settings"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Large text takes effect immediately and remains active when switching pages."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="18">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                        <Label Text="Theme mode"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}" />
                        <Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Choose app theme"
                                SelectedIndexChanged="OnThemeChanged"
                                SemanticProperties.Hint="Switch between system, light, and dark theme">
                            <Picker.Items>
                                <x:String>Use system theme</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Large text mode"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TertiaryAccent}, Dark={StaticResource TertiaryLight}}" />
                            <Label Text="Increase text size for accessibility demonstration."
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Increase text size across the current session" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryLight}, Dark={StaticResource SecondaryDark}}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.15" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryAccent}, Dark={StaticResource SecondaryLight}}" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="When enabled, this text and the rest of the page become visibly larger."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryAccent}, Dark={StaticResource PrimaryLight}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
